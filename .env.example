# ── PostgreSQL (direct TCP — used by Alembic and SQLAlchemy) ──────────────
# For local Docker: postgresql://sprintguard:sprintguard@localhost:5432/sprintguard
# For Supabase:     postgresql://postgres:[YOUR-PASSWORD]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://sprintguard:sprintguard@localhost:5432/sprintguard

# ── Supabase HTTPS client (used by FastAPI at runtime) ────────────────────
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_KEY=your-anon-or-service-role-key-here

# ── Docker / Compose ──────────────────────────────────────────────────────
POSTGRES_USER=sprintguard
POSTGRES_PASSWORD=sprintguard

# ── Application ───────────────────────────────────────────────────────────
MODEL_DIR=storage/models
LOG_LEVEL=info

# ── Dashboard ─────────────────────────────────────────────────────────────
# URL the Streamlit dashboard calls for API requests.
# Use http://api:8000 when running inside Docker Compose.
# Use http://localhost:8000 when running Streamlit locally.
API_BASE=http://localhost:8000
